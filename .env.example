# ============================================================
# WA-BAILEYS ENVIRONMENT CONFIGURATION
# ============================================================
# Salin file ini ke .env dan isi nilainya
# Jangan pernah commit file .env ke repository!
# ============================================================

# Port server berjalan
PORT=3000

# Base URL server (digunakan untuk generate URL media)
BASE_URL=http://localhost:3000

# API Key untuk mengamankan endpoint dari akses luar
# Isi dengan string acak yang kuat, contoh: gunakan password generator
# Consumer (IELC-CRM) wajib mengirimkan header: x-api-key: <nilai ini>
API_KEY=ganti_dengan_secret_key_yang_kuat

# Proxy configuration (Required if using Nginx/Reverse Proxy)
# Set to '1' if using a single proxy, or 'true' to trust all
TRUST_PROXY=1
